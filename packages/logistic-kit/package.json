{
  "name": "@dash-electric/logistic-kit",
  "version": "0.1.0",
  "description": "Dash Logistic Design System — the Dash UI atoms re-themed for Dash Logistic (delivery-orange accent). Ships raw .tsx + a self-contained token layer.",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "src/**/*.tsx",
    "src/**/*.css"
  ],
  "exports": {
    ".": "./src/index.tsx",
    "./styles": "./src/styles/tokens.css",
    "./lib/utils": "./src/lib/utils.tsx",
    "./*": "./src/*.tsx"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@remixicon/react": "^4.9.0",
    "@tiptap/extension-link": "^3.0.0",
    "@tiptap/extension-placeholder": "^3.0.0",
    "@tiptap/react": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.5"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "Dash Tech (PT Dash Elektrik Indonesia)",
  "license": "UNLICENSED"
}
